---
import Base from '../layouts/Base.astro';
import pages from '../data/pages.json';
import { cleanBody, rewriteCatalogLinks } from '../lib/html.js';
import GuideNav from '../components/GuideNav.astro';

export function getStaticPaths() {
  // Pages that have a hand-built custom template (must not also be generated here)
  const CUSTOM = new Set(['/spiritism-guide', '/biographies', '/spiritist-lexicon', '/activities-schedule', '/spiritist-materials', '/online-studies', '/spiritist-videos']);
  return pages
    .filter((p) => p.urlPath !== '/' && !p.urlPath.startsWith('/catalog') && !CUSTOM.has(p.urlPath))
    .map((p) => ({
      params: { slug: p.urlPath.replace(/^\//, '') },
      props: { page: p },
    }));
}

const { page } = Astro.props;
const body = rewriteCatalogLinks(cleanBody(page.bodyHtml));
const parts = page.urlPath.split('/').filter(Boolean);
const parent = parts.length > 1 ? '/' + parts[0] : null;
const parentLabel = parent ? parts[0].replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()) : null;
---
<Base title={page.title}>
  <section class="block">
    <div class="container article">
      <nav class="crumbs">
        <a href="/">Home</a>
        {parent && <> · <a href={parent}>{parentLabel}</a></>}
        <> · <span>{page.title}</span></>
      </nav>
      <GuideNav path={page.urlPath} pos="top" />
      <h1>{page.title}</h1>
      <div class="body" set:html={body}></div>
      <GuideNav path={page.urlPath} pos="bottom" />
    </div>
  </section>
</Base>
