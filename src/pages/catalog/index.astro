---
import Base from '../../layouts/Base.astro';
import catalog from '../../data/catalog.json';
import authors from '../../data/authors.json';

const books = catalog.filter((p) => p.type === 'book');
const byAuthor = new Map(authors.map((a) => [a.slug, { ...a, books: [] }]));
for (const b of books) if (byAuthor.has(b.author)) byAuthor.get(b.author).books.push(b);
const groups = [...byAuthor.values()].filter((g) => g.books.length);
const total = books.length;
---
<Base title="Book Catalog" description="Spiritist books in English, published and distributed at cost by the Spiritist Alliance Books program.">
  <section class="hero" style="padding-block:clamp(2.5rem,6vw,4rem)">
    <div class="container">
      <p class="eyebrow" style="color:#e9c878">Spiritist Alliance Books</p>
      <h1>Book Catalog</h1>
      <p>{total} Spiritist titles in English, distributed at cost. Browse by author below — or
        browse our free Virtual Library for the complete works of Chico Xavier and Allan Kardec.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/virtual-library">Browse the free Virtual Library →</a>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="container">
      <nav class="crumbs" style="display:flex;flex-wrap:wrap;gap:.5rem">
        {authors.map((a) => <a href={`#${a.slug}`} class="btn btn-outline" style="padding:.3rem .7rem;font-size:.82rem">{a.name} ({a.count})</a>)}
      </nav>

      {groups.map((g) => (
        <div id={g.slug} style="margin-top:3rem;scroll-margin-top:5rem">
          <h2 style="border-bottom:1px solid var(--line);padding-bottom:.5rem;margin-bottom:1.5rem">{g.name}</h2>
          <div class="book-grid">
            {g.books.map((b) => (
              <a class="book" href={b.path}>
                <div class="cover">{b.cover && <img src={b.cover} alt={`Cover of ${b.title}`} loading="lazy" />}</div>
                <div class="title">{b.title}</div>
                {b.price ? <div class="price">{b.price}</div> : <div class="by">View details</div>}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
