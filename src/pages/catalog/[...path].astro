---
import Base from '../../layouts/Base.astro';
import catalog from '../../data/catalog.json';

export function getStaticPaths() {
  // Every catalog page EXCEPT the /catalog landing (handled by index.astro)
  return catalog
    .filter((p) => p.path !== '/catalog')
    .map((p) => ({ params: { path: p.path.replace(/^\/catalog\//, '') }, props: { page: p } }));
}
const { page } = Astro.props;
// Only show child links to catalog pages that still exist — this drops links to
// the removed collection / "and other authors" / category pages (no more dead links).
const validPaths = new Set(catalog.map((p) => p.path.replace(/\/$/, '')));
const children = (page.children ?? []).filter((c) => validPaths.has(String(c.href).replace(/\/$/, '')));

const segs = page.path.split('/').filter(Boolean);
const crumbs = segs.map((s, i) => ({
  label: i === 0 ? 'Catalog' : (page.authorName && i === 2 ? page.authorName : s.replace(/-/g, ' ')),
  href: '/' + segs.slice(0, i + 1).join('/'),
}));
const paypal = page.type === 'book' && page.forSale && page.amount;
---
<Base title={page.title} description={page.blurb || page.intro?.slice(0, 150)}>
  <section class="block">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Home</a>
        {crumbs.map((c, i) => <> · {i < crumbs.length - 1 ? <a href={c.href} style="text-transform:capitalize">{c.label}</a> : <span style="text-transform:capitalize">{page.title}</span>}</>)}
      </nav>

      {page.type === 'book' ? (
        <div>
          <div style="display:grid;gap:2.5rem;grid-template-columns:minmax(200px,280px) 1fr;align-items:start">
            <div>
              <div class="cover" style="aspect-ratio:2/3;border-radius:12px;overflow:hidden;box-shadow:var(--shadow);background:var(--accent-soft)">
                {page.cover && <img src={page.cover} alt={`Cover of ${page.title}`} style="width:100%;height:100%;object-fit:cover" />}
              </div>
              {page.price && (
                <div class="card" style="margin-top:1.25rem;text-align:center">
                  <div style="font-size:1.5rem;font-family:var(--serif);color:var(--brand-dark)">{page.price}</div>
                  {page.format && <div class="muted" style="font-size:.85rem;text-transform:capitalize">{page.format}</div>}
                  {paypal ? (
                    <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="paypal" style="margin-top:.9rem">
                      <input type="hidden" name="cmd" value="_xclick" />
                      <input type="hidden" name="business" value="sab-books@sgny.org" />
                      <input type="hidden" name="item_name" value={page.title} />
                      <input type="hidden" name="amount" value={page.amount} />
                      <input type="hidden" name="currency_code" value="USD" />
                      <button class="btn btn-primary" type="submit" style="width:100%;justify-content:center">Buy with PayPal</button>
                    </form>
                  ) : (
                    <a class="btn btn-outline" href="/contact-us" style="margin-top:.9rem;width:100%;justify-content:center">Ask about availability</a>
                  )}
                </div>
              )}
            </div>
            <div class="article" style="margin:0">
              {page.newRelease && <p class="eyebrow" style="margin-bottom:.4rem">★ New Release{page.releaseLabel ? ` · ${page.releaseLabel}` : ''}</p>}
              <h1 style="margin-bottom:.2em">{page.title}</h1>
              {page.authorName && <p class="muted" style="font-size:1.1rem;margin-top:0">by {page.authorName}</p>}
              {page.synopsis && (
                <div class="body" style="margin-top:1.5rem">
                  <h2 style="font-size:1.3rem">Synopsis</h2>
                  {page.synopsis.split(/\n+/).map((p) => <p>{p}</p>)}
                </div>
              )}
              {page.bibliography && (
                <div style="margin-top:2rem">
                  <h2 style="font-size:1.3rem">Bibliographic information</h2>
                  <table class="bib">
                    <tbody>
                      {Object.entries(page.bibliography).map(([k, v]) => (
                        <tr><th scope="row">{k}</th><td>{v}</td></tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          </div>
        </div>
      ) : (
        <div>
          <h1>{page.title}</h1>
          {page.intro && children.length === 0 && <p class="muted" style="max-width:60ch">{page.intro}</p>}
          <div class="book-grid" style="margin-top:2rem">
            {children.map((c) => (
              <a class="book" href={c.href}>
                <div class="cover">
                  {c.cover
                    ? <img src={c.cover} alt={`Cover of ${c.text}`} loading="lazy" />
                    : <span style="font-family:var(--serif);color:var(--brand);padding:1rem;text-align:center;font-size:1rem">{c.text}</span>}
                </div>
                <div class="title">{c.text}</div>
                {c.price && <div class="price">{c.price}</div>}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .bib { width: 100%; border-collapse: collapse; margin-top: .75rem; font-size: .92rem; }
  .bib th, .bib td { text-align: left; vertical-align: top; padding: .55rem .75rem;
    border-bottom: 1px solid var(--line); }
  .bib th { width: 38%; font-weight: 600; color: var(--brand-dark); }
  .bib td { color: var(--ink-soft); }
</style>
