---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found" description="That page could not be found on the Spiritist Group of New York website.">
  <section class="hero" style="padding-block:clamp(3rem,9vw,6rem)">
    <div class="container" style="text-align:center;max-width:60ch;margin-inline:auto">
      <p class="eyebrow" style="color:#e9c878">404 · Page not found</p>
      <h1>We couldn’t find that page</h1>
      <p>The page may have moved, or the link may be out of date. Let’s guide you back.</p>
      <div class="actions" style="justify-content:center">
        <a class="btn btn-primary" href="/">Return home</a>
        <a class="btn btn-ghost" href="/virtual-library">Visit the Library</a>
        <a class="btn btn-ghost" href="/activities-schedule">See activities</a>
      </div>
    </div>
  </section>
</Base>
