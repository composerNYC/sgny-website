---
import Base from '../layouts/Base.astro';
import { tracks } from '../data/guide-nav.js';
import { figures } from '../data/lexicon.js';
import { bios } from '../data/biographies.js';

const guide = tracks.find((t) => t.name === 'A Guide to Spiritism');
const mediumship = tracks.find((t) => t.name === 'Mediumship');
const initials = (n) => n.split(' ').filter(Boolean).map((w) => w[0]).slice(0, 2).join('');

// One-line orientation for each main-guide step (keeps the cards from being bare links).
const guideBlurbs = {
  '/spiritism-guide/a-history': 'How the Doctrine was revealed and codified in 19th-century France.',
  '/spiritism-guide/the-fundamentals': 'The core principles that define what Spiritism is — and isn’t.',
  '/spiritism-guide/teachings-outline': 'A bird’s-eye outline of the spirits’ teachings.',
  '/spiritism-guide/teachings-precepts': 'The moral precepts drawn from those teachings.',
  '/spiritism-guide/the-5-book-codification': 'The five works of the Codification and how to study them.',
  '/spiritism-guide/the-5-book-codification-ii': 'Continuing the study of the foundational books.',
  '/spiritism-guide/spiritism-topics': 'Selected subjects explored in greater depth.',
  '/spiritism-guide/spiritism-topics/spiritism-ethics': 'Spiritism as a guide to ethical living.',
  '/spiritism-guide/spiritism-topics/spiritism-and-identity': 'The Spiritist view of the self and identity.',
  '/spiritism-guide/myths-and-misconceptions': 'Clearing up the most common misunderstandings.',
  '/spiritism-guide/spiritist-centers-guide': 'What a Spiritist center is and how it works.',
};
---
<Base title="A Guide to Spiritism" description="A complete introduction to Spiritism — its history and fundamentals, a deeper study of mediumship, the great names who shaped it, and biographies of renowned Spiritists.">

  <section class="hero">
    <div class="hero-mist" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
    <div class="container">
      <p class="eyebrow" style="color:#e9c878">Learn</p>
      <h1>A Guide to Spiritism</h1>
      <p>An ever-expanding guide to Spiritism — for the curious and the student
        alike. Begin with the fundamentals, go deeper into mediumship, and meet the lives
        that carried Spiritism to the world.</p>
    </div>
  </section>

  <nav class="page-nav" aria-label="On this page">
    <div class="container page-nav-inner">
      <a href="#guide">The Guide</a>
      <a href="#mediumship">Mediumship</a>
      <a href="#great-names">Great Names</a>
      <a href="#biographies">Biographies</a>
    </div>
  </nav>

  <!-- ===== The Guide ===== -->
  <section class="block" id="guide">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Start Here</p>
        <h2>The Guide</h2>
        <p>Eleven short chapters that introduce Spiritism from the ground up. Read them in
          order, or jump to whatever draws you.</p>
      </div>
      <ol class="step-grid">
        {guide.steps.map((s, i) => (
          <li>
            <a href={s.path} class="step-card">
              <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="step-body">
                <span class="step-title">{s.label}</span>
                {guideBlurbs[s.path] && <span class="step-blurb">{guideBlurbs[s.path]}</span>}
              </span>
              <span class="step-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== Mediumship ===== -->
  <section class="block band" id="mediumship">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">A Deeper Study</p>
        <h2>Mediumship</h2>
        <p>A thorough, {mediumship.steps.length}-part study of mediumship — what a spirit is, how
          communication works, the types of phenomena and mediums, and the trials along the way.</p>
      </div>
      <div class="medium-panel">
        <ol class="medium-list">
          {mediumship.steps.map((s, i) => (
            <li>
              <a href={s.path}>
                <span class="m-num">{i + 1}</span>
                <span>{s.label}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ===== Great Names (Lexicon) ===== -->
  <section class="block" id="great-names">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The Spiritist Lexicon</p>
        <h2>The Great Names</h2>
        <p>The people whose lives and works shaped the Doctrine — from its Codifier to the
          mediums and thinkers who carried it across the world.</p>
      </div>
      <div class="fig-list">
        {figures.map((f, i) => (
          <article class="fig-row" data-flip={i % 2 === 1 ? 'true' : undefined}>
            <div class="fig-portrait">
              {f.image
                ? <img src={f.image} alt={`Portrait of ${f.name}`} loading="lazy" />
                : <div class="fig-monogram" aria-label={`Portrait of ${f.name} coming soon`}>{initials(f.name)}</div>}
            </div>
            <div class="fig-text">
              <span class="fig-role">{f.role}</span>
              <h3>{f.name}</h3>
              <p class="fig-meta">{f.years} · {f.country}</p>
              <p class="fig-bio">{f.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Biographies ===== -->
  <section class="block band" id="biographies">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The Full Collection</p>
        <h2>Biographies</h2>
        <p>The fuller library of renowned Spiritists — scientists, mediums, writers, and
          philosophers. Select a name to read the full biography.</p>
      </div>
      <ul class="bio-grid">
        {bios.map((b) => (
          <li>
            <a href={`/biographies/${b.slug}`} class="bio-card">
              <span class="bio-portrait">
                {b.image
                  ? <img src={b.image} alt={`Portrait of ${b.name}`} loading="lazy" />
                  : <span class="bio-monogram">{initials(b.name)}</span>}
              </span>
              <span class="bio-info">
                <span class="bio-name">{b.name}</span>
                <span class="bio-meta">{b.years} · {b.country}</span>
                <span class="bio-blurb">{b.blurb}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Base>

<style>
  /* sticky in-page section nav */
  .page-nav { position: sticky; top: 57px; z-index: 30; background: rgba(251,250,247,.9);
    backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
  .page-nav-inner { display: flex; gap: .25rem; flex-wrap: wrap; overflow-x: auto; }
  .page-nav a { padding: .85rem .9rem; font-size: .9rem; font-weight: 600; color: var(--ink-soft);
    text-decoration: none; border-bottom: 2px solid transparent; white-space: nowrap; }
  .page-nav a:hover { color: var(--brand-dark); border-color: var(--accent); }

  .band { background: var(--accent-soft); }

  /* ---- The Guide: numbered step cards ---- */
  .step-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); }
  .step-card { display: flex; align-items: flex-start; gap: 1rem; height: 100%;
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.2rem 1.3rem; text-decoration: none; color: inherit; box-shadow: var(--shadow);
    transition: transform .12s ease, border-color .15s ease, box-shadow .15s ease; }
  .step-card:hover { transform: translateY(-3px); border-color: var(--accent);
    box-shadow: 0 10px 28px rgba(28,36,48,.1); }
  .step-num { font-family: var(--serif); font-size: 1.35rem; font-weight: 600; color: var(--accent);
    line-height: 1; padding-top: .15rem; min-width: 1.8em; }
  .step-body { display: flex; flex-direction: column; gap: .25rem; flex: 1; }
  .step-title { font-family: var(--serif); font-weight: 600; font-size: 1.12rem; color: var(--ink); }
  .step-blurb { font-size: .92rem; color: var(--ink-soft); line-height: 1.45; }
  .step-arrow { color: var(--accent); font-size: 1.1rem; align-self: center;
    transition: transform .15s ease; }
  .step-card:hover .step-arrow { transform: translateX(4px); }

  /* ---- Mediumship list panel ---- */
  .medium-panel { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
    box-shadow: var(--shadow); padding: 1rem clamp(1rem, 3vw, 2rem); max-width: 960px; margin-inline: auto; }
  .medium-list { list-style: none; margin: 0; padding: 0; columns: 2; column-gap: 2.5rem; }
  .medium-list li { break-inside: avoid; }
  .medium-list a { display: flex; align-items: baseline; gap: .7rem; padding: .6rem .2rem;
    border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink); font-size: .98rem; }
  .medium-list a:hover { color: var(--brand); }
  .medium-list a:hover .m-num { background: var(--accent); color: #2a1d05; }
  .m-num { flex: none; width: 1.6rem; height: 1.6rem; display: grid; place-items: center;
    border-radius: 50%; background: var(--accent-soft); color: var(--brand-dark);
    font-size: .78rem; font-weight: 700; align-self: center; transition: background .15s ease; }

  /* ---- Great Names (portrait rows) ---- */
  .fig-list { display: grid; gap: clamp(2.5rem, 5vw, 4rem); max-width: 980px; margin-inline: auto; }
  .fig-row { display: grid; grid-template-columns: 240px 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .fig-row[data-flip] .fig-portrait { order: 2; }
  .fig-portrait { aspect-ratio: 4/5; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow);
    background: linear-gradient(160deg, #2b6098, #163a5c); }
  .fig-portrait img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(15%) contrast(1.03); }
  .fig-monogram { width: 100%; height: 100%; display: grid; place-items: center; color: #e9c878;
    font-family: var(--serif); font-size: 4rem; letter-spacing: .05em; }
  .fig-role { display: inline-block; text-transform: uppercase; letter-spacing: .12em; font-size: .76rem;
    font-weight: 700; color: var(--accent); margin-bottom: .5rem; }
  .fig-text h3 { font-size: clamp(1.6rem, 3.4vw, 2.2rem); margin: 0 0 .25rem; }
  .fig-meta { color: var(--ink-soft); font-weight: 500; margin: 0 0 1rem; font-size: .98rem; }
  .fig-bio { color: var(--ink-soft); margin: 0; font-size: 1.05rem; }

  /* ---- Biographies grid ---- */
  .bio-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); }
  .bio-card { display: flex; gap: 1rem; height: 100%; background: var(--surface);
    border: 1px solid var(--line); border-radius: var(--radius); padding: 1rem; text-decoration: none;
    color: inherit; box-shadow: var(--shadow); transition: transform .12s ease, border-color .15s ease; }
  .bio-card:hover { transform: translateY(-3px); border-color: var(--accent); }
  .bio-portrait { flex: none; width: 84px; height: 104px; border-radius: 10px; overflow: hidden;
    background: linear-gradient(160deg, #2b6098, #163a5c); display: grid; place-items: center; }
  .bio-portrait img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(12%); }
  .bio-monogram { color: #e9c878; font-family: var(--serif); font-size: 1.7rem; }
  .bio-info { display: flex; flex-direction: column; gap: .2rem; }
  .bio-name { font-family: var(--serif); font-weight: 600; font-size: 1.1rem; color: var(--ink); }
  .bio-meta { font-size: .8rem; color: var(--accent); font-weight: 600; }
  .bio-blurb { font-size: .9rem; color: var(--ink-soft); line-height: 1.45; margin-top: .15rem; }

  @media (max-width: 720px) {
    .fig-row, .fig-row[data-flip] .fig-portrait { grid-template-columns: 1fr; order: 0; }
    .fig-portrait { max-width: 220px; margin-inline: auto; }
    .fig-text { text-align: center; }
    .medium-list { columns: 1; }
  }
</style>
