# Prayer book configuration.
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
#
# In production, set these same two variables in the Netlify dashboard:
#   Site settings -> Environment variables.

# The single shared password volunteers type to open /prayer-book
PRAYER_BOOK_PASSWORD="change-this-to-a-strong-shared-password"

# A long random string used to sign the login session cookie.
# Generate one with:  openssl rand -hex 32
PRAYER_SESSION_SECRET="change-this-to-a-long-random-string"
